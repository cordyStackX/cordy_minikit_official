{
  "name": "@cordystackx/cordy_minikit",
  "version": "2.0.6",
  "publishConfig": {
    "access": "public"
  },
  "description": "Cordy Minikit - Open Source Web3 Dev Toolkit for both EVM and Non-EVM Wallets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && pnpm run copy-css",
    "copy-css": "mkdir -p dist/css/UI_Comp && cp css/UI_Comp/styles.module.css dist/css/UI_Comp/",
    "npm-release": "pnpm publish --registry=https://registry.npmjs.org/ --access public",
    "github-release": "pnpm publish --registry=https://npm.pkg.github.com/"
  },
  "keywords": [
    "web3",
    "nextjs",
    "react",
    "wagmi",
    "viem",
    "ethers",
    "blockchain",
    "wallet-connect",
    "npm-package",
    "cordy-minikit",
    "EVM Wallets",
    "Non-EVM Wallets",
    "Stellar",
    "Coinbased"
  ],
  "author": "Marc Giestin Louis Cordova a.k.a. (CordyStackX)",
  "license": "MIT",
  "dependencies": {
    "@coinbase/wallet-sdk": "4.3.7",
    "@metamask/connect-evm": "^2.1.0",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@tanstack/react-query": "^5.101.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "ethers": "^6.17.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "viem": "^2.53.1",
    "wagmi": "^3.6.17"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
