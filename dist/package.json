{
    "name": "@cordystackx/cordy_minikit",
    "version": "1.5.17",
    "publishConfig": {
        "access": "public"
    },
    "description": "Cordy Minikit - Open Source Web3 Dev Toolkit (Wallet Connect, Tx, Disconnect)",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && pnpm run copy-css",
        "copy-css": "mkdir -p dist/css/UI_Comp && cp css/UI_Comp/styles.module.css dist/css/UI_Comp/",
        "npm-release": "pnpm publish --registry=https://registry.npmjs.org/ --access public",
        "github-release": "pnpm publish --registry=https://npm.pkg.github.com/"
    },
    "keywords": [
        "web3",
        "nextjs",
        "react",
        "wagmi",
        "viem",
        "ethers",
        "blockchain",
        "wallet-connect",
        "npm-package",
        "cordy-minikit"
    ],
    "author": "Marc Giestin Louis Cordova",
    "license": "MIT",
    "dependencies": {
        "@coinbase/wallet-sdk": "4.3.7",
        "@tanstack/react-query": "^5.101.0",
        "ethers": "^6.17.0",
        "next": "^16.2.9",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-icons": "^5.6.0",
        "wagmi": "^3.6.17"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3"
    }
}
